<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ROOT MENU = APP ICON -->
        <menuitem id="menu_hr_payroll_root"
                  name="Simple Payroll"
                  sequence="10"
                  web_icon="hr_payroll_simple,static/description/icon.png"/>

        <!-- ACTION -->
        <record id="action_hr_payslip_custom" model="ir.actions.act_window">
            <field name="name">Payslips</field>
            <field name="res_model">hr.payslip</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- SUB MENU -->
        <menuitem id="menu_hr_payslip"
                  name="Payslips"
                  parent="menu_hr_payroll_root"
                  action="action_hr_payslip_custom"/>

    </data>
</odoo>