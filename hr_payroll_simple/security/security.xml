<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <!-- Custom groups -->
    <record id="group_hr_payroll_manager" model="res.groups">
        <field name="name">Payroll Manager</field>
    </record>

    <record id="group_hr_payroll_employee" model="res.groups">
        <field name="name">Employee (Payroll)</field>
    </record>

    <!-- Record rule for employees: only see their own payslips -->
    <record id="hr_payslip_employee_rule" model="ir.rule">
        <field name="name">Employee: own payslips only</field>
        <field name="model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="groups" eval="[(4, ref('group_hr_payroll_employee'))]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    </data>
</odoo>