<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hospital_patient_tree" model="ir.ui.view">
        <field name="name">hospital.patient.list</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="phone"/>
            </list>
        </field>
    </record>

    <record id="view_hospital_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="gender"/>
                        <field name="phone"/>
                        <field name="email"/>
                    </group>
                    <notebook>
                        <page string="Appointments">
                            <field name="appointment_ids" mode="list,form">
                                <list>
                                    <field name="date"/>
                                    <field name="doctor_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hospital_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hospital_main" name="Hospital" sequence="10"/>
    <menuitem id="menu_hospital_patients" name="Patients" parent="menu_hospital_main" action="action_hospital_patient" sequence="20"/>
</odoo>