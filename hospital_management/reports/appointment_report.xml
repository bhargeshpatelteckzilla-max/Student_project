<odoo>
    <data>

        <record id="action_report_appointment" model="ir.actions.report">
            <field name="name">Appointment Report</field>
            <field name="model">hospital.appointment.report.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hospital_management.report_appointment_template</field>
            <field name="report_file">hospital_management.report_appointment_template</field>
            <field name="print_report_name">'Appointments - %s' % (object.date_from or '')</field>
        </record>

    </data>
</odoo>